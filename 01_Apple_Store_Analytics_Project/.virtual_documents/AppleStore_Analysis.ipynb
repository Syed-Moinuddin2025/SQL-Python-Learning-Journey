plt.title(' Top 5 Stores – Avg Sale per Transaction', fontsize=13, weight='bold')
plt.xlabel('Store Name')
plt.ylabel('Avg Sale Amount ($)')
plt.xticks(rotation=40, ha='right')
plt.tight_layout()
# Grid line removed

plt.show()




